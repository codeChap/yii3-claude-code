{
    "name": "codechap/yii3-claude-code",
    "description": "Yii3 wrapper for the Claude Code CLI with DI integration, multi-turn conversations, and immutable fluent API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["yii3", "claude", "claude-code", "ai", "anthropic", "cli"],
    "autoload": {
        "psr-4": {
            "Codechap\\Yii3ClaudeCode\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codechap\\Yii3ClaudeCode\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "CodeChap",
            "email": "hello@codechap.com"
        }
    ],
    "require": {
        "php": "8.2 - 8.5",
        "symfony/console": "^6.0 || ^7.0",
        "symfony/process": "^6.0 || ^7.0",
        "yiisoft/friendly-exception": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "vimeo/psalm": "^5.26.1 || ^6.13.1"
    },
    "suggest": {
        "yiisoft/yii-console": "Required for using the claude:query console command with the Yii3 console runner"
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php",
            "params-console": "params-console.php",
            "di": "di.php",
            "di-console": "$di"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "analyse": "psalm --no-cache"
    },
    "config": {
        "sort-packages": true
    }
}
